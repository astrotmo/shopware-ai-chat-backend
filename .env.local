# ---- Shopware Admin API (read-only integration token) ----
SHOPWARE_BASE_URL=http://host.docker.internal:8000
SHOPWARE_CLIENT_ID=
SHOPWARE_CLIENT_SECRET=
DEFAULT_LOCALE=de-DE

# ---- Ollama (OpenAI-compatible endpoint) ----
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.1:8b
# Fallback for all models (optional)
OLLAMA_NUM_CTX=8192
# Per-model overrides: model=num_ctx,model2=num_ctx
OLLAMA_NUM_CTX_BY_MODEL=llama3.1:8b=8192,gpt-oss:20b=8192,ministral-3:8b=8192,qwen3.5:9b=8192
# Optional model aliases (recommended for per-model context on Ollama OpenAI API)
OLLAMA_MODEL_ALIAS_BY_MODEL=llama3.1:8b=llama3.1:8b-8k,gpt-oss:20b=gpt-oss:20b-8k,ministral-3:8b=ministral-3:8b-8k,qwen3.5:9b=qwen3.5:9b-8k
OLLAMA_DEBUG=0

# ---- Server settings ----
CHAT_HOST=0.0.0.0
CHAT_PORT=8002
CHAT_LOGGING_LEVEL=debug
CHAT_AUTH_SECRET=
CHAT_DRY_RUN=0
DOMAIN_KNOWLEDGE_ENABLED=1

# Optional: restrict CORS in production, comma-separated origins
CORS_ORIGINS=http://localhost:8000,http://localhost:5173,http://192.168.0.131:8000,http://178.24.216.115:8000

# ---- MCP settings ----
MCP_URL=http://mcp:8005/mcp
MCP_LOGGING_LEVEL=info

# ---- Trace settings ----
TRACE_ENABLED=1